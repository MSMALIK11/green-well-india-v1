# Copy to .env.local (local dev). On Vercel: Project Settings → Environment Variables (same names).

# Must be reachable from the internet on Vercel (not 127.0.0.1). Use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/greenwell?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/greenwell_fullstack

JWT_SECRET=change-me-min-32-chars-use-openssl-rand-base64-32

# Optional: your real site URL (production custom domain). If unset on Vercel, https://VERCEL_URL is used.
# CLIENT_ORIGIN=https://your-domain.com

# Optional seed overrides (npm run seed)
# SEED_EMAIL=admin@greenwell.local
# SEED_PASSWORD=ChangeMe123!
# SEED_NAME=Green Well Admin
